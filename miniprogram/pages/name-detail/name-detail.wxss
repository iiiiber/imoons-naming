.detail-page {
  padding-bottom: 160rpx;
}

.hero {
  background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
  color: #fff;
  padding: 64rpx 32rpx 48rpx;
  text-align: center;
}

.hero-name {
  font-size: 96rpx;
  font-weight: 700;
  font-family: "STKaiti", "KaiTi", "STSong", serif;
  letter-spacing: 12rpx;
  line-height: 1.2;
}

.hero-pinyin {
  font-size: 28rpx;
  margin-top: 12rpx;
  opacity: 0.9;
  letter-spacing: 4rpx;
}

.hero-wuxing {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.wx-chip {
  min-width: 36rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
}

.hero-score {
  font-size: 24rpx;
  margin-top: 12rpx;
  background: rgba(255,255,255,0.2);
  display: inline-block;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}

.text-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
  white-space: pre-wrap;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  border-top: 2rpx solid var(--border);
  display: flex;
  gap: 16rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.action-bar .btn {
  flex: 1;
}
