<view class="articles-page">
  <view wx:if="{{loading && list.length === 0}}" class="empty">
    <text class="text-muted">加载中...</text>
  </view>
  <view wx:elif="{{list.length === 0}}" class="empty">
    <text class="empty-icon">📚</text>
    <text class="text-muted">暂无文章</text>
  </view>
  <view wx:else class="article-list">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="article-card"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="article-title text-lg font-semibold">{{item.title}}</view>
      <view wx:if="{{item.summary}}" class="article-summary text-sm text-secondary mt-1">
        {{item.summary}}
      </view>
      <view class="article-meta text-xs text-muted mt-2">
        {{item.author || '起名网'}} · {{item.published_at || item.created_at}}
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="text-center text-muted text-sm mt-2">加载中...</view>
    <view wx:elif="{{!hasMore && list.length > 0}}" class="text-center text-muted text-sm mt-2">— 已显示全部 —</view>
  </view>
</view>
