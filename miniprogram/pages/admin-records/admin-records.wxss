.records-page {
  padding-bottom: 40rpx;
}

.filter-bar {
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-input {
  flex: 1;
  background: #f3f4f6;
  border-radius: 8rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
}

.filter-date {
  background: #f3f4f6;
  border-radius: 8rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
}

.filter-chip {
  padding: 8rpx 20rpx;
  background: #f3f4f6;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.chip-active-blue {
  background: #dbeafe;
  color: #1d4ed8;
}

.chip-active-pink {
  background: #fce7f3;
  color: #be185d;
}

.filter-spacer {
  flex: 1;
}

.record-list {
  padding: 20rpx 24rpx;
}

.record-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
}

.record-names {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.name-chip {
  padding: 4rpx 14rpx;
  background: #dbeafe;
  color: #1e40af;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.record-bazi {
  font-family: monospace;
  margin-top: 4rpx;
}
