<wxs module="util">
function parseNames(names) {
  if (!names) return []
  if (typeof names === 'string') {
    try { names = JSON.parse(names) } catch (e) { return [] }
  }
  if (!Array.isArray(names)) return []
  return names
}

function nameStr(n) {
  if (!n) return ''
  if (typeof n === 'string') return n
  return n.name || n.fullName || ''
}

function wxArr(wx) {
  if (!wx) return []
  return wx.split('')
}

module.exports = { parseNames: parseNames, nameStr: nameStr, wxArr: wxArr }
</wxs>

<view class="records-page">
  <view wx:if="{{loading && list.length === 0}}" class="empty text-muted">加载中...</view>
  <view wx:elif="{{list.length === 0}}" class="empty">
    <text class="empty-icon">📋</text>
    <text class="text-muted">暂无起名记录</text>
    <view class="mt-3 text-muted text-sm">去试试智能起名吧</view>
  </view>
  <view wx:else>
    <view wx:for="{{list}}" wx:key="id" class="record-card">
      <view class="record-header">
        <text class="record-surname">姓 {{item.surname}}</text>
        <text class="text-muted text-xs">{{item.gender === 'boy' ? '♂' : '♀'}} {{item.birthday}}</text>
      </view>

      <!-- 名字预览 -->
      <view class="record-names">
        <view
          wx:for="{{util.parseNames(item.names)}}"
          wx:for-item="n"
          wx:key="*this"
          class="record-name-chip"
        >{{util.nameStr(n)}}</view>
      </view>

      <view wx:if="{{item.bazi}}" class="record-bazi text-xs text-muted mt-1">
        八字：{{item.bazi}}
      </view>
      <view class="record-time text-xs text-muted">
        {{item.created_at || item.createdAt}}
      </view>
    </view>
  </view>
</view>
