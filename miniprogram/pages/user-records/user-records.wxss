.records-page {
  padding: 24rpx;
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-surname {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.record-names {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.record-name-chip {
  padding: 8rpx 20rpx;
  background: #dbeafe;
  color: #1e40af;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.record-bazi {
  font-family: monospace;
}

.record-time {
  margin-top: 8rpx;
}
