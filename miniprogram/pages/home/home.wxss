.home-page {
  padding-bottom: 40rpx;
}

.banner-section {
  background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
  color: #fff;
  padding: 48rpx 32rpx 64rpx;
  text-align: center;
}

.banner-title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.entry-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -40rpx 24rpx 0;
  position: relative;
  z-index: 2;
}

.entry-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.entry-text {
  font-size: 24rpx;
  color: var(--text-primary);
}

.cta-section {
  padding: 24rpx;
}

.article-item {
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.article-item:last-child {
  border-bottom: none;
}

.article-title {
  margin-bottom: 8rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
