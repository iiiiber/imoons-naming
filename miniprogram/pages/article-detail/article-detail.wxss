.detail-page {
  padding: 0;
}

.article-header {
  background: #fff;
  padding: 32rpx 24rpx 24rpx;
  border-bottom: 2rpx solid var(--border);
}

.article-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.article-meta {
  font-size: 22rpx;
}

.article-content {
  background: #fff;
  padding: 32rpx 24rpx;
  margin-top: 16rpx;
}

.article-summary {
  background: #eff6ff;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
  border-left: 6rpx solid var(--primary);
}

.article-body {
  font-size: 30rpx;
  line-height: 1.9;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-all;
}
