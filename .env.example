# ========================================
# 数据库配置（PHP 后端用）
# ========================================
DB_HOST=127.0.0.1
DB_NAME=name_imoons_cn
DB_USER=name_imoons_cn
DB_PASS=your_password_here

# ========================================
# AI 接口配置（存数据库 configs 表）
# ========================================
AI_API_URL=https://api.minimaxi.com/v1/chat/completions
AI_API_KEY=sk-cp-your-key-here
AI_MODEL=MiniMax-M3

# ========================================
# 微信开放平台（公众号 H5 登录）
# ========================================
WX_APPID=your_wx_appid
WX_APPSECRET=your_wx_appsecret

# ========================================
# 管理员账号（首次部署后改）
# ========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123  # ⚠️ 首次登录后立即修改
